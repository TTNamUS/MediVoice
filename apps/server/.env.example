# ── LLM provider ─────────────────────────────────────────────────────────────
# Select which LLM backend to use: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Default: claude-haiku-4-5-20251001  (override to claude-sonnet-4-6 for harder reasoning)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Default: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# ── Deepgram (STT) ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ── Cartesia (TTS) ───────────────────────────────────────────────────────────
CARTESIA_API_KEY=...
# Default voice: Sonic-2 English female. Find IDs at https://play.cartesia.ai
CARTESIA_VOICE_ID=694f9389-aac1-45b6-b726-9d9369183238

# ── LiveKit (browser WebRTC + SIP dial-in) ──────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=...
LIVEKIT_SIP_TRUNK_ID=ST_...

# ── Langfuse (observability) ─────────────────────────────────────────────────
# Get keys from https://cloud.langfuse.com → Project → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Port 4319: OTel Collector gRPC (4317 is taken by Jaeger inside docker network)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4319
OTEL_SERVICE_NAME=medivoice-server

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIM=1536

# ── Voyage AI (dense embeddings for RAG) ───────────────────────────────────────
# Primary: voyage-3 (best retrieval quality). Fallback: OPENAI_API_KEY above.
VOYAGE_API_KEY=pa-...

# ── Qdrant (vector DB) ─────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=clinic_kb_v1

# ── Postgres ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://medivoice:medivoice@localhost:5432/medivoice

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

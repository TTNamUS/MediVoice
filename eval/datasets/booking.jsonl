{"id": "book-001", "category": "happy_path", "description": "Existing patient books hygiene cleaning", "steps": [{"role": "user", "text": "I'd like to book a cleaning next Tuesday afternoon"}, {"role": "tool", "name": "lookup_patient", "expect_called": true}, {"role": "tool", "name": "check_availability", "expect_args": {"specialty": "hygiene", "time_of_day": "afternoon"}}, {"role": "tool", "name": "book_appointment", "expect_called": true}], "expected_outcome": "appointment_confirmed"}
{"id": "book-002", "category": "new_patient", "description": "New patient not found, bot collects info", "steps": [{"role": "user", "text": "I need to see Dr. Patel for my child"}, {"role": "tool", "name": "lookup_patient", "expect_called": true, "returns_found": false}], "expected_outcome": "collect_patient_info"}
{"id": "book-003", "category": "no_availability", "description": "No slots available for requested specialty and date", "steps": [{"role": "user", "text": "Book orthodontics for tomorrow morning"}, {"role": "tool", "name": "check_availability", "returns_available": false}], "expected_outcome": "offer_alternative_date"}
{"id": "book-004", "category": "specialty_mismatch", "description": "Patient asks for service, bot maps to correct specialty", "steps": [{"role": "user", "text": "I need braces consultation"}, {"role": "tool", "name": "check_availability", "expect_args": {"specialty": "orthodontics"}}], "expected_outcome": "availability_checked_orthodontics"}
{"id": "book-005", "category": "slot_conflict", "description": "Selected slot already booked, bot finds alternative", "steps": [{"role": "tool", "name": "book_appointment", "returns": "slot_already_booked"}], "expected_outcome": "offer_alternative_slot"}
{"id": "book-006", "category": "phone_confirmation", "description": "Bot reads back phone number before lookup", "steps": [{"role": "user", "text": "My number is 555-0101"}, {"role": "assistant_must_contain", "text": "555-0101"}], "expected_outcome": "phone_confirmed_before_lookup"}
{"id": "book-007", "category": "morning_preference", "description": "Patient requests morning appointment", "steps": [{"role": "user", "text": "General checkup, I prefer mornings"}, {"role": "tool", "name": "check_availability", "expect_args": {"time_of_day": "morning"}}], "expected_outcome": "morning_slots_returned"}
{"id": "book-008", "category": "idempotent_booking", "description": "Same booking request made twice — no duplicate", "steps": [{"role": "tool", "name": "book_appointment", "called_twice_same_args": true}], "expected_outcome": "single_appointment_created"}
{"id": "book-009", "category": "mid_flow_hangup", "description": "Call ends after check_availability but before booking", "steps": [{"role": "tool", "name": "check_availability", "expect_called": true}, {"role": "event", "type": "disconnect"}], "expected_outcome": "no_appointment_created"}
{"id": "book-010", "category": "emergency", "description": "Patient reports tooth pain, emergency specialty", "steps": [{"role": "user", "text": "I have severe tooth pain, I need to be seen today"}, {"role": "tool", "name": "check_availability", "expect_args": {"specialty": "emergency"}}], "expected_outcome": "emergency_slots_checked"}
{"id": "book-011", "category": "happy_path", "description": "Booking general checkup any time", "steps": [{"role": "user", "text": "Book a general checkup, I'm flexible on time"}, {"role": "tool", "name": "check_availability", "expect_args": {"specialty": "general"}}], "expected_outcome": "availability_returned"}
{"id": "book-012", "category": "voice_format", "description": "Bot reads slots as natural speech not a list", "steps": [{"role": "tool", "name": "check_availability", "returns_slots": 2}], "expected_outcome": "voice_friendly_response"}
{"id": "book-013", "category": "confirmation", "description": "Bot confirms appointment details after booking", "steps": [{"role": "tool", "name": "book_appointment", "returns": "booked"}], "expected_outcome": "confirmation_read_back"}
{"id": "book-014", "category": "no_availability_all_doctors", "description": "Specialty has no available slots in any range", "steps": [{"role": "tool", "name": "check_availability", "returns_available": false}], "expected_outcome": "graceful_no_availability_message"}
{"id": "book-015", "category": "pediatric", "description": "Parent books for child with Dr. Patel", "steps": [{"role": "user", "text": "My daughter needs a pediatric checkup"}, {"role": "tool", "name": "check_availability", "expect_args": {"specialty": "pediatric"}}], "expected_outcome": "pediatric_slots_returned"}
